OwnershipChecker::OwnershipChecker() : verbose_(false) {
}

OwnershipChecker::~OwnershipChecker() = default;

void OwnershipChecker::check(void* ast_root) {
    if (!ast_root) return;
    
    // Enter global scope
    context_.enter_scope();
    
    // Walk the AST - this is a simplified implementation
    // In a full implementation, we would walk the actual AST nodes
    walk_node(ast_root);
    
    // Exit global scope
    context_.exit_scope();
}

void OwnershipChecker::report_error(OwnershipErrorKind kind, std::string_view var_name,
                                   std::string_view message, uint32_t line, uint32_t column) {
    OwnershipError error;
    error.kind = kind;
    error.message = std::string(message);
    error.variable_name = std::string(var_name);
    error.point = context_.get_current_point();
    error.line = line;
    error.column = column;
    errors_.push_back(error);
    
    if (verbose_) {
        std::cerr << "Ownership Error: " << error.to_string() << "\n";
    }
}

