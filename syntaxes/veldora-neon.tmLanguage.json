{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "VeldoCra Neon Blue",
  "author": "Dr. Bright",
  "description": "VeldoCra syntax highlighting with Neon Blue cycling colors for keywords",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords_genesis"
    },
    {
      "include": "#keywords_control"
    },
    {
      "include": "#keywords_functions"
    },
    {
      "include": "#keywords_oop"
    },
    {
      "include": "#keywords_memory"
    },
    {
      "include": "#keywords_system"
    },
    {
      "include": "#keywords_error"
    },
    {
      "include": "#keywords_module"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#types"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.veldocra",
          "begin": "#",
          "end": "$"
        },
        {
          "name": "comment.line.double-slash.veldocra",
          "begin": "//",
          "end": "$"
        },
        {
          "name": "comment.line.cmt.veldocra",
          "begin": "\\bcmt\\b",
          "end": "$"
        },
        {
          "name": "comment.block.veldocra",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.block.mul_cmt.veldocra",
          "begin": "\\bmul_cmt\\s*\\{",
          "end": "\\}"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.veldocra",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.veldocra",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.veldocra",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.veldocra",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.triple.veldocra",
          "begin": "\"\"\"",
          "end": "\"\"\""
        }
      ]
    },
    "keywords_genesis": {
      "patterns": [
        {
          "name": "keyword.genesis.veldocra.neon",
          "match": "\\b(av|limit|immo|omni|evolve|species)\\b"
        },
        {
          "name": "keyword.genesis.veldocra.neon_bright",
          "match": "\\b(senect|print)\\b"
        }
      ]
    },
    "keywords_control": {
      "patterns": [
        {
          "name": "keyword.control.veldocra.neon",
          "match": "\\b(verdict|fail|path|analysis|cycle|sustain|samsara|end|skip)\\b"
        }
      ]
    },
    "keywords_functions": {
      "patterns": [
        {
          "name": "keyword.function.veldocra.neon",
          "match": "\\b(ability|feat|hax|scale|stasis|non_linear|wait)\\b"
        }
      ]
    },
    "keywords_oop": {
      "patterns": [
        {
          "name": "keyword.oop.veldocra.neon",
          "match": "\\b(race|avatar|grant|blessing|contract|glory|void|core|ego)\\b"
        }
      ]
    },
    "keywords_memory": {
      "patterns": [
        {
          "name": "keyword.memory.veldocra.neon",
          "match": "\\b(vec|echo|touch|forge|pur|clm|rsz|ee|manifest|forbidden|anomaly|cap)\\b"
        },
        {
          "name": "keyword.memory.veldocra.neon_bright",
          "match": "\\b(ee_inf_layers)\\b"
        }
      ]
    },
    "keywords_system": {
      "patterns": [
        {
          "name": "keyword.system.veldocra.neon",
          "match": "\\b(flow|sink|rise|summon|resoul|leap|halt|inhale|exhale)\\b"
        },
        {
          "name": "keyword.system.veldocra.neon_bright",
          "match": "\\b(origin|petition)\\b"
        }
      ]
    },
    "keywords_error": {
      "patterns": [
        {
          "name": "keyword.error.veldocra.neon",
          "match": "\\b(clash|counter|debuff|dispel)\\b"
        },
        {
          "name": "keyword.error.veldocra.neon_bright",
          "match": "\\b(lowdiff|end_of_canon)\\b"
        }
      ]
    },
    "keywords_module": {
      "patterns": [
        {
          "name": "keyword.module.veldocra.neon",
          "match": "\\b(absorb|federation|legion|proclaim|alias|domain)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.veldocra",
          "match": "(:=|->|==|!=|>=|<=|=>|<-|->|\\+|-|\\*|/|%|>|<|!|&|\\||&&|\\|\\|)"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.veldocra",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        },
        {
          "name": "constant.numeric.hex.veldocra",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.veldocra",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.octal.veldocra",
          "match": "\\b0[oO][0-7]+\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.veldocra",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.veldocra",
          "match": "\\b(string|number|bool|array|dict|void|int|float|char|bool)\\b"
        }
      ]
    }
  },
  "scopeName": "source.veldocra.neon"
}

